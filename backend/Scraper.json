    {
      "parameters": {
        "jsCode": "const content = $('Read URL content').first().json.content;\nconst urlRegex = /https?:\\/\\/[^\\s\\)\\]]+/g;\nconst links = content.match(urlRegex) || [];\n\nconst validLinks = [...new Set(links)].filter(link => {\n    const isImage = /\\.(png|jpg|jpeg|gif|webp|svg|bmp|ico|tiff)(\\?.*)?$/i.test(link);\n    return !isImage;\n});\n\nreturn {\n    json: {\n        all_links: validLinks \n    }\n};"
      },
