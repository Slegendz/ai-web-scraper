    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0 || !items[0].json.valid_data) {\n  return [{ json: { success: false, message: \"Data not found\", timestamp: new Date().toISOString() } }];\n}\n\nconst validDataArray = items[0].json.valid_data;\nconst sources = items[0].json.source_url;\n\nconst mergedData = validDataArray.reduce((acc, curr) => ({ ...acc, ...curr }), {});\n\nreturn [{ json: { success: true, data: mergedData, sources, timestamp: new Date().toISOString() } }];"
      },
